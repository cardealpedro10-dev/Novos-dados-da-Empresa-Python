import time
import random

def simular_jornada_uber():
    print("=" * 60)
    print("    A JORNADA DE PEDRO: CONSTRUINDO A RESERVA EM 5 ANOS")
    print("=" * 60)
    print("\nPedro roda como motorista de aplicativo. Cansado de viver no limite,")
    print("ele traçou uma meta: construir sua independência e reserva de emergência")
    print("investindo mensalmente durante os próximos 5 anos (60 meses).")
    print("\nSua estratégia de alocação de investimentos é:")
    print("- 40% em Tesouro Direto (Segurança máxima)")
    print("- 30% em CDB 100% CDI (Liquidez para emergências)")
    print("- 15% em FIIs de Tijolo (Imóveis físicos reais)")
    print("- 15% em FIIs de Papel (Títulos de crédito imobiliário)")
    print("-" * 60)
   
    input("\nPressione ENTER para iniciar a jornada de 5 anos...")

    # Variáveis Financeiras Iniciais
    meses_totais = 60
   
    # Saldos acumulados nos ativos
    tesouro_direto = 0.0
    cdb_cdi = 0.0
    fii_tijolo = 0.0
    fii_papel = 0.0
   
    # Taxas médias estimadas de rendimento mensal (Hipótese de mercado estático)
    # Valores fictícios apenas para ilustrar o efeito dos juros compostos
    tx_tesouro = 0.008   # ~0.8% ao mês
    tx_cdb = 0.0085     # ~0.85% ao mês
    tx_tijolo = 0.007    # ~0.7% ao mês + valorização patrimonial discreta
    tx_papel = 0.009     # ~0.9% ao mês (geralmente pagam dividendos maiores)

    for mes in range(1, meses_totais + 1):
        # 1. Narrativa de storytelling baseada no dia a dia do motorista
        print(f"\n--- MÊS {mes}/{meses_totais} ---")
       
        # Simulação de flutuação de receita do Uber (meses bons e meses fracos)
        receita_bruta = random.randint(5500, 7500)
        custos_carro = random.randint(2800, 3500) # Gasolina, parcela, seguro, óleo
        lucro_liquido = receita_bruta - custos_carro
       
        print(f"Faturamento Bruto nas pistas: R$ {receita_bruta:.2f}")
        print(f"Custos Operacionais (Combustível/Manutenção): R$ {custos_carro:.2f}")
        print(f"Sobrou no bolso do Pedro: R$ {lucro_liquido:.2f}")
       
        # Eventos aleatórios de Storytelling que impactam as finanças
        evento = random.random()
        if evento < 0.15:
            print("[EVENTO]: O pneu furou na linha amarela e a suspensão cobrou o preço. Gasto extra de R$ 600.")
            lucro_liquido -= 600
        elif evento > 0.85:
            print("[EVENTO]: Semana de grandes eventos e feriado na cidade! Muita tarifa dinâmica. Bônus de R$ 800.")
            lucro_liquido += 800

        # Pedro decide poupar rigidamente 20% do que sobra líquido para a sua meta
        aporte_mensal = max(lucro_liquido * 0.20, 200.0) # Garante um aporte mínimo mesmo em meses ruins
        print(f"Aporte investido este mês: R$ {aporte_mensal:.2f}")

        # 2. Divisão Matemática do Aporte (Soma exatamente 100%)
        p_tesouro = aporte_mensal * 0.40
        p_cdb = aporte_mensal * 0.30
        p_tijolo = aporte_mensal * 0.15
        p_papel = aporte_mensal * 0.15
       
        # 3. Aplicação dos Juros Compostos + Novos Aportes
        tesouro_direto = (tesouro_direto + p_tesouro) * (1 + tx_tesouro)
        cdb_cdi = (cdb_cdi + p_cdb) * (1 + tx_cdb)
        fii_tijolo = (fii_tijolo + p_tijolo) * (1 + tx_tijolo)
        fii_papel = (fii_papel + p_papel) * (1 + tx_papel)
       
        total_acumulado = tesouro_direto + cdb_cdi + fii_tijolo + fii_papel
        print(f"Patrimônio total evoluindo: R$ {total_acumulado:.2f}")
       
        # Efeito visual de passagem de tempo rápida no terminal
        if mes in [1, 12, 24, 36, 48, 59]:
            time.sleep(1)
        elif mes == 60:
            print("\nChegamos ao final do prazo estipulado...")
            time.sleep(1.5)

    # --- RELATÓRIO FINAL DA HISTÓRIA ---
    print("\n" + "=" * 60)
    print("           RESULTADO DA JORNADA DE 5 ANOS")
    print("=" * 60)
    print("Pedro manteve a disciplina de ferro rodando no aplicativo.")
    print("Mesmo pegando trânsito, passageiro difícil e dias de chuva, o resultado veio.\n")
   
    print("Divisão do Patrimônio Conquistado:")
    print(f"• Tesouro Direto (40%):    R$ {tesouro_direto:.2f}")
    print(f"• CDB 100% CDI (30%):      R$ {cdb_cdi:.2f}")
    print(f"• FIIs de Tijolo (15%):    R$ {fii_tijolo:.2f}")
    print(f"• FIIs de Papel (15%):     R$ {fii_papel:.2f}")
    print("-" * 40)
   
    patrimonio_final = tesouro_direto + cdb_cdi + fii_tijolo + fii_papel
    print(f"RESERVA TOTAL ACUMULADA: R$ {patrimonio_final:.2f}")
    print("=" * 60)
   
    if patrimonio_final >= 45000:
        print("Resultado: Pedro agora tem uma reserva extremamente robusta!")
        print("Ele pode escolher os melhores dias para rodar ou até migrar de carreira com total segurança.")
    else:
        print("Resultado: A meta foi atingida! Pedro criou seu colchão financeiro e não depende mais de empréstimos.")

if __name__ == "__main__":
    simular_jornada_uber()
